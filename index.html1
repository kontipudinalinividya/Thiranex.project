<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Responsive Portfolio</title>
<link rel="stylesheet" href="style.css">
</head>

<body>

<header class="header">
<h1>My Portfolio</h1>

<nav>
<ul class="nav-links">
<li><a href="#">Home</a></li>
<li><a href="#">About</a></li>
<li><a href="#">Projects</a></li>
<li><a href="#">Contact</a></li>
</ul>
</nav>

<button onclick="toggleTheme()">Theme</button>

</header>

<main class="grid-container">

<section class="card">
<h2>About Me</h2>
<p>I am learning Advanced CSS3 and Responsive Design.</p>
</section>

<section class="card">
<h2>Projects</h2>
<p>Responsive Portfolio Website using Grid and Flexbox.</p>
</section>

<section class="card">
<h2>Skills</h2>
<p>HTML5, CSS3, Responsive Design</p>
</section>

</main>

<script>
function toggleTheme() {
document.body.classList.toggle("dark");
}
</script>

</body>
</html>